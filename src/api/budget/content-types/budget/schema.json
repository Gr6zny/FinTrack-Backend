{
  "kind": "collectionType",
  "collectionName": "budgets",
  "info": {
    "singularName": "budget",
    "pluralName": "budgets",
    "displayName": "Budget"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "period": {
      "type": "enumeration",
      "enum": [
        "weekly",
        "monthly",
        "quarterly",
        "yearly",
        "custom"
      ]
    },
    "start_date": {
      "type": "date"
    },
    "end_date": {
      "type": "date"
    },
    "amount": {
      "type": "decimal"
    },
    "spent_amount": {
      "type": "decimal"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "budgets"
    },
    "notifications": {
      "type": "boolean"
    },
    "threshold_percent": {
      "type": "integer"
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "budgets"
    }
  }
}
