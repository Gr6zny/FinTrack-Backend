    },
    "account_from": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::account.account",
      "inversedBy": "transactions"
    },
    "account_to": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::account.account",
      "inversedBy": "transaction"
    },
    "is_recurring": {
      "type": "boolean"
    },
    "recurring_rule": {
      "type": "json"
    },
    "location": {
