{
  "kind": "collectionType",
  "collectionName": "reports",
  "info": {
    "singularName": "report",
    "pluralName": "reports",
    "displayName": "Report"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "monthly",
        "yearly",
        "custom",
        "category"
      ]
    },
    "period_start": {
      "type": "date"
    },
    "period_end": {
      "type": "date"
    },
    "data": {
      "type": "json"
    },
    "is_saved": {
      "type": "boolean"
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "reports"
    }
  }
}
