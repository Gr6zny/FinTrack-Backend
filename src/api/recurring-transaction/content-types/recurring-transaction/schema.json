{
  "kind": "collectionType",
  "collectionName": "recurring_transactions",
  "info": {
    "singularName": "recurring-transaction",
    "pluralName": "recurring-transactions",
    "displayName": "RecurringTransaction"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
