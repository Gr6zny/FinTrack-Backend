{
  "kind": "collectionType",
  "collectionName": "up_users",
  "info": {
    "name": "user",
    "description": "",
    "singularName": "user",
    "pluralName": "users",
    "displayName": "User"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "username": {
      "type": "string",
      "minLength": 3,
      "unique": true,
      "configurable": false,
      "required": true
    },
    "email": {
      "type": "email",
      "minLength": 6,
      "configurable": false,
      "required": true
    },
    "provider": {
      "type": "string",
      "configurable": false
    },
    "password": {
      "type": "password",
      "minLength": 6,
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "resetPasswordToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmationToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmed": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "blocked": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "role": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.role",
      "inversedBy": "users",
      "configurable": false
    },
    "currency": {
      "type": "string"
    },
    "monthly_budget": {
      "type": "decimal"
    },
    "savings_goal": {
      "type": "decimal"
    },
    "notifications_enabled": {
      "type": "boolean"
    },
    "transactions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::transaction.transaction",
      "mappedBy": "users_permissions_user"
    },
    "account": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::account.account",
      "mappedBy": "users_permissions_user"
    },
    "budgets": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::budget.budget",
      "mappedBy": "users_permissions_user"
    },
    "recurring_transactions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::recurring-transaction.recurring-transaction",
      "mappedBy": "users_permissions_user"
    },
    "debts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::debt.debt",
      "mappedBy": "users_permissions_user"
    },
    "reports": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::report.report",
      "mappedBy": "users_permissions_user"
    },
    "tags": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tags.tags",
      "mappedBy": "users_permissions_user"
    }
  }
}
